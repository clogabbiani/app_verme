{
  "expo": {
    "name": "TCG Collector",
    "slug": "tcg-collector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tcgcollector",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tcgcollector.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan your TCG cards",
        "NSLocationWhenInUseUsageDescription": "Used to find traders near you"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.tcgcollector.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TCG Collector to access your camera to scan cards."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow TCG Collector to access your location to find nearby traders."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
